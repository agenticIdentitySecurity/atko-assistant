# Okta Org AS — used for OIDC login and ID-JAG exchange (step 1 of XAA)
OKTA_ORG_URL=https://your-org.okta.com
OKTA_CLIENT_ID=0oa...
OKTA_CLIENT_SECRET=...
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback

# Okta AI Agent service app — used for CrossAppAccessFlow (JWT Bearer / client assertion)
# Registered under Directory → AI Agents and linked to the OIDC app above
OKTA_SERVICE_CLIENT_ID=wlp...
OKTA_SERVICE_KEY_PATH=./private_key.pem
OKTA_SERVICE_KEY_ID=<kid-from-okta-agent-credentials-tab>

# Custom Authorization Server (Managed Connection) for the MCP Resource Server
OKTA_MCP_RESOURCE_SERVER_ISSUER=https://your-org.okta.com/oauth2/aus...
OKTA_MCP_AUDIENCE=api://mcp-resource-server

# Service Account — for elevated ROPG flow (add_subscription, etc.)
SERVICE_ACCOUNT_USERNAME=svc-atko-agent@your-org.com
SERVICE_ACCOUNT_PASSWORD=...

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://llm.your-company.ai
ANTHROPIC_MODEL=claude-sonnet-4-6

# Session encryption (random 32+ char string)
SESSION_SECRET_KEY=change-me-to-a-long-random-secret

# SQLite database file path
DATABASE_PATH=./ai_agent.db

# Path to MCP server script (relative to project root)
MCP_SERVER_SCRIPT=mcp_server/server.py
