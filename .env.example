# Okta OIDC (consumer-facing web app)
OKTA_ISSUER=https://dev-xxxxx.okta.com/oauth2/default
OKTA_CLIENT_ID=0oa...
OKTA_CLIENT_SECRET=...
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback

# Okta Service App — used for CrossAppAccessFlow (JWT Bearer / client assertion)
# This is a separate Okta application configured with an RS256 private key
OKTA_SERVICE_CLIENT_ID=0oa...
OKTA_SERVICE_KEY_PATH=./private_key.pem

# Custom Authorization Server created for the MCP Resource Server
OKTA_MCP_RESOURCE_SERVER_ISSUER=https://dev-xxxxx.okta.com/oauth2/mcp-resource-server
OKTA_MCP_AUDIENCE=api://mcp-resource-server

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Session encryption (random 32+ char string)
SESSION_SECRET_KEY=change-me-to-a-long-random-secret

# SQLite database file path
DATABASE_PATH=./ai_agent.db

# Path to MCP server script (relative to project root)
MCP_SERVER_SCRIPT=mcp_server/server.py
